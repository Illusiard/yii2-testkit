server {
    listen 80;
    server_name _;
    root /testkit-web-root;
    index ${TESTKIT_ENTRY_SCRIPT} index.php;

    location / {
        try_files $uri $uri/ /${TESTKIT_ENTRY_SCRIPT}?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass php-fpm:9000;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param SCRIPT_NAME $fastcgi_script_name;
    }
}
